# pubspec.lock SÍ se versiona (es una app): fija las versiones exactas para que
# el build en CI use las mismas que funcionan en local y no derive a versiones
# incompatibles (p. ej. firebase_messaging). No lo ignores.
frontend/ios/Pods/
frontend/android/.gradle/

