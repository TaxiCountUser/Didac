# ============================================================
# TaxiCount - Variables de entorno (ejemplo)
# Copia este archivo a `.env` y ajusta los valores.
# Las claves ANON/SERVICE de abajo son las claves DEMO públicas
# de Supabase, válidas SOLO para desarrollo local.
# ============================================================

# --- Postgres ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- JWT / Supabase keys (DEMO - solo local) ---
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# anon (rol "anon")
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MjAwMDAwMDAwMH0.ZxBhVEYye2lqm5NDdkey-JP6uTHcqvZriXUoBtyQniY

# service_role (rol "service_role", bypassa RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDAwfQ.8T3kmJ5SaqY3bVmU02ZJ4MIoHe5z7R4qQ4T9VqJA8hk

# URL del gateway (Kong) expuesto al host
SUPABASE_URL=http://localhost:54321

# Para el backend (dentro de la red docker apunta a kong)
SUPABASE_INTERNAL_URL=http://kong:8000

# --- Backend Fastify ---
BACKEND_PORT=3000

# --- Integraciones externas (placeholders) ---
OPENAI_API_KEY=sk-placeholder-openai-key

# --- Stripe (Fase 4) — usa claves de TEST (sk_test_... / whsec_...) ---
STRIPE_SECRET_KEY=sk_test_placeholder_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_placeholder_webhook_secret
# Price IDs de los planes (modo test). Mapeo de límite de conductores:
#   Starter -> 2 | Pro -> 10 | Business -> ilimitado
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_BUSINESS=price_business_placeholder
# URLs de retorno de Checkout (deep links de la app)
STRIPE_SUCCESS_URL=taxicount://subscription-success
STRIPE_CANCEL_URL=taxicount://subscription-cancel
