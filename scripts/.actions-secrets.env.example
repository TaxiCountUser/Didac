# ============================================================
# Plantilla de secrets/variables de GitHub Actions para TaxiCount.
# Copia este fichero a `scripts/.actions-secrets.env` (gitignored) y rellena
# los valores. Luego ejecuta:  bash scripts/setup-actions-secrets.sh
#
# NUNCA comitees el fichero relleno. Solo se versiona este .example vacío.
# ============================================================

# Repo destino (owner/repo). Por defecto se detecta del remoto origin.
REPO="TaxiCountUser/Didac"

# --- Variables (activan los deploys; déjalas en "true" cuando estés listo) ---
DEPLOY_VPS="false"
DEPLOY_WEB="false"
BUILD_MOBILE="false"

# --- Secrets: Backend -> VPS ---
VPS_HOST=""
VPS_USER=""
VPS_SSH_KEY=""          # contenido de la clave PRIVADA (multilínea permitido)

# --- Secrets: Web -> Vercel ---
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
PROD_SUPABASE_URL=""
PROD_SUPABASE_ANON_KEY=""
PROD_BACKEND_URL="https://api.taxicount.app"
PROD_STRIPE_PRICE_STARTER=""
PROD_STRIPE_PRICE_PRO=""
PROD_STRIPE_PRICE_BUSINESS=""
